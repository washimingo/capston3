# Configuración del Backend SII

# Puerto del servidor
PORT=3000

# Ambiente por defecto (certificacion o produccion)
AMBIENTE_DEFAULT=certificacion

# Seguridad - CORS
CORS_ORIGIN=http://localhost:8100

# Opcional: Si quieres preconfigurar el certificado (NO RECOMENDADO en producción)
# CERT_RUT=12345678-9
# CERT_PASSWORD=tu_password_aqui
# CERT_PATH=./certificado.pfx

# Logs
LOG_LEVEL=info

# Duración del token en cache (en horas)
TOKEN_CACHE_HOURS=6
